# --- Release announcements ---
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=channel-for-release-announcements
# Must match the secret configured in GitHub -> repo Settings -> Webhooks
GITHUB_WEBHOOK_SECRET=your-webhook-secret
# Optional but recommended on shared hosts (Render): raises the GitHub API
# rate limit for the language button's release lookups from 60/hr (per shared
# IP) to 5000/hr. Fine-grained token, public repos, read-only.
# GITHUB_TOKEN=github_pat_...

# --- AI chat (leave unset to run release-announcements-only) ---
# Requires MESSAGE CONTENT INTENT enabled in the Discord developer portal.
OPENROUTER_API_KEY=your-openrouter-key
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discordbot
# Comma-separated = primary + fallbacks when the primary is rate-limited,
# e.g. OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free,meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
# SHORT_TERM_LIMIT=10
# SUMMARY_EVERY=20
# KNOWLEDGE_FILE=knowledge.md
# SYSTEM_PROMPT=custom persona override (default persona + safety prompt is built in)
